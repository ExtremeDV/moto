[{"data":1,"prerenderedAt":416},["ShallowReactive",2],{"navigation":3,"index":14,"index-blogs":203,"projects-page":256,"projects":271,"$fL9wwD8_g42qyXenWtjV3OqT_Hzda_QR3Q_Z9BLenkB4":316},[4],{"title":5,"path":6,"stem":7,"children":8,"page":13},"Blog","/blog","blog",[9],{"title":10,"path":11,"stem":12},"А что и мне надо правила знать? Я же пассажир, а не водитель.","/blog/pravila-passajira","blog/pravila-passajira",false,{"id":15,"title":16,"about":17,"blog":20,"body":23,"description":26,"experience":152,"extension":162,"faq":163,"features":168,"hero":176,"meta":191,"navigation":192,"path":31,"seo":193,"stem":194,"testimonials":195,"__hash__":202},"index/index.yml","Мотошкола в Подольске",{"title":18,"description":19},"О нас","Мы — маленькая семейная мотошкола. Мы заинтересованы , чтобы люди уезжали от нас с хорошим настроением и рекомендовали нас своим друзьям и знакомым. Все занятия веду я. Большинство наших учеников сдают экзамен с первого раза.\n",{"title":21,"description":22},"Интересные статьи","Читаем полезные статьи о мотошколе, обучении и безопасности на дороге",{"seo":24,"title":16,"description":26,"hero":27,"about":67,"experience":68,"testimonials":95,"blog":108,"faq":109,"features":124},{"title":25,"description":26},"Школамото.рф - Мотошкола в Подольске","Обучаем категории «А» на площадке ГИБДД в Подольске c 2013 г. Индивидуальный подход и график занятий",{"links":28,"images":33},[29],{"label":30,"to":31,"color":32},"записаться на обучение","/","primary",[34,37,40,43,46,49,52,55,58,61,64],{"src":35,"alt":36},"/images/slider/001.jpg","Random Image 1",{"src":38,"alt":39},"/images/slider/002.jpg","Random Image 2",{"src":41,"alt":42},"/images/slider/003.jpg","Random Image 3",{"src":44,"alt":45},"/images/slider/004.jpg","Random Image 4",{"src":47,"alt":48},"/images/slider/005.jpg","Random Image 5",{"src":50,"alt":51},"/images/slider/006.jpg","Random Image 6",{"src":53,"alt":54},"/images/slider/007.jpg","Random Image 7",{"src":56,"alt":57},"/images/slider/008.jpg","Random Image 8",{"src":59,"alt":60},"/images/slider/009.jpg","Random Image 9",{"src":62,"alt":63},"/images/slider/010.jpg","Random Image 10",{"src":65,"alt":66},"/images/slider/011.jpg","Random Image 11",{"title":18,"description":19},{"title":69,"items":70},"В нашей школе:",[71,78,84,90],{"position":72,"date":73,"company":74},"Сдают экзамен в ГИБДД с первого раза","95 из 100",{"name":75,"logo":76,"url":75,"color":77},"","material-symbols:sports-motorsports-outline","#00DC82",{"position":79,"date":80,"company":81},"Переобучение за 1 месяц с «В» на «А»","29000 руб.",{"name":75,"logo":82,"url":75,"color":83},"ic:round-motorcycle","#FF6363",{"position":85,"date":86,"company":87},"Разовое занятие","3000 руб.",{"name":75,"logo":88,"url":75,"color":89},"streamline:class-lesson","#5E6AD2",{"position":91,"date":92,"company":93},"Рассрочка платежа","15000 + 14000",{"name":75,"logo":94,"url":75,"color":77},"material-symbols:credit-card-clock-outline",[96,104],{"quote":97,"author":98},"Почему человек садится на мотоцикл? Для кого-то это способ самовыражения, для кого-то давняя детская мечта, а для кого-то просто способ добраться на работу минуя пробки… Не важно. Главное, чтобы для Вас это был сплошной позитив и безграничное удовольствие.",{"name":99,"description":100,"avatar":101},"Роман Лисов","Инструктор Школамото.рф",{"src":102,"srcset":103},"/images/RomaAvatar.jpg","https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=80&h=80&q=80 2x",{"quote":105,"author":106},"Мы — маленькая семейная мотошкола. Мы заинтересованы , чтобы люди уезжали от нас с хорошим настроением и рекомендовали нас своим друзьям и знакомым. Все занятия веду я. Большинство наших учеников сдают экзамен с первого раза.",{"avatar":107,"name":99,"description":100},{"src":102},{"title":21,"description":22},{"title":110,"description":111,"categories":112},"Курсы и ответы на частые вопросы","Выбирай подходящий для тебя курс",[113,117,121],{"title":114,"description":115,"price":116},"Краткий курс","Если у вас уже есть водительское удостоверение на автомобиль — то это курс для вас. Длится он месяц и состоит из краткого курса теории и 18 часов практики на мотоцикле. Теорию для сдачи в ГИБДД вы готовите удаленно.   Запись в группы идет с середины марта по конец сентября. Каждый месяц новая группа.","29000",{"title":118,"description":119,"price":120},"Полный курс","Если у вас нет прав и вы хотите открыть категорию «А», «А1» или «М», то полный (базовый) курс для вас. Длится он 2 месяца и состоит из полного курса теории и 18 часов практики на мотоцикле. Теорию для сдачи в ГИБДД вы готовите удаленно. Занятия по теории проходят удаленно.","33000",{"title":85,"description":122,"price":123},"Чем наполнить разовое занятие решаете вы. Одним оно будет полено, чтобы безопасно привыкнуть к своему мотоциклу. Другим чтобы привыкнуть к нашей площадке для сдачи экзамена в ГИБДД после обучения в другой школе. Длительность разового занятия — 60 минут.","3000",{"title":125,"description":126,"feature":127},"Вот часть из базовых умений мотоциклиста.","Вы научитесь:\n",[128,132,136,140,144,148],{"title":129,"description":130,"icon":131},"Пользованию органами управления","«А эта красная кнопочка здесь зачем? На ней странный значок такой…», — «Это кнопка экстренного выключения двигателя. Она нужна чтобы заглушить двигатель не снимая рук с руля»","i-lucide-bike",{"title":133,"description":134,"icon":135},"Маневрированию","Мотоцикл гораздо уже автомобиля и обладает большей маневренностью в ряде ситуаций. Многие приобретают мотоцикл как транспортное средство, позволяющее добираться на работу минуя пробки.","i-lucide-rocket",{"title":137,"description":138,"icon":139},"Правильной посадке на мотоцикле","Какими частями тела Вы заставите повернуть свой мотоцикл? Руками? А вот и нет! А смотреть чем собираетесь? Глазами? Опять не угадали!","i-lucide-loader-pinwheel",{"title":141,"description":142,"icon":143},"Поведению в экстренных ситуациях","Тяжело в учении — легко в бою! Очень важно, чтобы при выезде на дорогу Вы знали как себя вести при неожиданных действиях других участников дорожного движения.","i-lucide-file-warning",{"title":145,"description":146,"icon":147},"Медленной езде","Навык медленной езды крайне необходим при движении в условиях плотного городского движения.","i-lucide-turtle",{"title":149,"description":150,"icon":151},"Обслуживанию мотоцикла","«А че-то он у меня как-то в повороте вилять начал?», — «А давление в колесах давно проверялось?» Для безопасной езды необходимо вовремя и качественно обслуживать мотоцикл.","i-lucide-settings",{"title":69,"items":153},[154,156,158,160],{"position":72,"date":73,"company":155},{"name":75,"logo":76,"url":75,"color":77},{"position":79,"date":80,"company":157},{"name":75,"logo":82,"url":75,"color":83},{"position":85,"date":86,"company":159},{"name":75,"logo":88,"url":75,"color":89},{"position":91,"date":92,"company":161},{"name":75,"logo":94,"url":75,"color":77},"yml",{"title":110,"description":111,"categories":164},[165,166,167],{"title":114,"description":115,"price":116},{"title":118,"description":119,"price":120},{"title":85,"description":122,"price":123},{"title":125,"description":126,"feature":169},[170,171,172,173,174,175],{"title":129,"description":130,"icon":131},{"title":133,"description":134,"icon":135},{"title":137,"description":138,"icon":139},{"title":141,"description":142,"icon":143},{"title":145,"description":146,"icon":147},{"title":149,"description":150,"icon":151},{"links":177,"images":179},[178],{"label":30,"to":31,"color":32},[180,181,182,183,184,185,186,187,188,189,190],{"src":35,"alt":36},{"src":38,"alt":39},{"src":41,"alt":42},{"src":44,"alt":45},{"src":47,"alt":48},{"src":50,"alt":51},{"src":53,"alt":54},{"src":56,"alt":57},{"src":59,"alt":60},{"src":62,"alt":63},{"src":65,"alt":66},{},true,{"title":25,"description":26},"index",[196,199],{"quote":97,"author":197},{"name":99,"description":100,"avatar":198},{"src":102,"srcset":103},{"quote":105,"author":200},{"avatar":201,"name":99,"description":100},{"src":102},"pPowxJa9Uac2UUlMbjUPAeG1_5xg_aDyzMNfWE90CBc",[204],{"id":205,"title":10,"author":206,"body":208,"date":248,"description":249,"extension":250,"image":251,"meta":252,"minRead":253,"navigation":192,"path":11,"seo":254,"stem":12,"__hash__":255},"blog/blog/pravila-passajira.md",{"name":99,"avatar":207},{"src":102,"alt":99},{"type":209,"value":210,"toc":241},"minimark",[211,216,220,224,227,231,234,238],[212,213,215],"h2",{"id":214},"_1-посадка-и-сход-с-мотоцикла","1. Посадка и сход с мотоцикла",[217,218,219],"p",{},"Если мотоцикл не высокий, то садиться можно с земли, если высокий, то с задних подножек. При посадке придержитесь за плечи водителя и перекиньте одну ногу через мотоцикл. Осторожно, не заденьте кофр (хозяева это очень не любят).При посадке и сходе с мотоцикла дождитесь сигнала водителя, разрешающего Вам совершить какое-либо действие. Обычно, водитель подает сигнал \"можно\" поднятием и опусканием плеч.",[212,221,223],{"id":222},"_2-как-держаться-за-водителя","2. Как держаться за водителя",[217,225,226],{},"Прежде всего, держаться нужно ногами, сжимая своими бедрами бедра водителя. Руками вы придерживаетесь дополнительно.Поместите руки на талию водителя, держитесь удобным крепким хватом, но старайтесь не стеснять движения водителя. При наличии специальных ручек можно держаться и за них, но, на наш взгляд, держаться за водителя удобнее и надёжнее.",[212,228,230],{"id":229},"_3-нестандартные-ситуации","3. Нестандартные ситуации",[217,232,233],{},"Если вы чувствуете занос/мотоцикл начинает падать, обнимите водителя и прижмитесь к нему, чтобы сохранить равновесие. Не делайте резких движений, так как это может усугубить ситуацию. Следуйте указаниям водителя и постарайтесь не паниковать.",[212,235,237],{"id":236},"_4-дополнительные-советы","4. Дополнительные советы:",[217,239,240],{},"- Носите защитную одежду, включая шлем, перчатки и обувь ВСЕГДА.- Информируйте водителя о любых изменениях в своем состоянии или  дискомфорте.- Сообщайте водителю заранее оговоренным \"знаком\" о препятствиях или опасностях на дороге. Будьте с водителем \"одним целым\" - если он привстает при проезде через препятствия, то привставайте вместе с ним как бы \"одной конструкцией\", без резких движений, не создавая диссонанс.- Уважайте водителя и его решения, не отвлекайте его без повода.Соблюдение этих правил поможет обеспечить безопасность и комфорт как водителя, так и пассажира. Наслаждайтесь прекрасной совместной поездкой на мотоцикле!",{"title":75,"searchDepth":242,"depth":242,"links":243},2,[244,245,246,247],{"id":214,"depth":242,"text":215},{"id":222,"depth":242,"text":223},{"id":229,"depth":242,"text":230},{"id":236,"depth":242,"text":237},"2025-06-08T00:00:00.000Z","- Да, если Вы пассажир, то для приятных и безопасных поездок Вы тоже должны соблюдать некоторые правила. Сейчас расскажем об основных из них.","md","/images/blog/post_1.jpg",{},8,{"title":10,"description":249},"O-I7FVpXy7KkG2OBUhMmhzCqXljWc7Ebe-kydSr067I",{"id":257,"title":258,"body":259,"description":260,"extension":162,"links":264,"meta":266,"navigation":192,"path":267,"seo":268,"stem":269,"__hash__":270},"pages/projects.yml","Школа Мото для тебя",{"title":258,"description":260,"links":261},"Обучение, которое подходит всем!",[262],{"label":263,"color":32}," Записаться на обучение",[265],{"label":263,"color":32},{},"/projects",{"title":258,"description":260},"projects","NV6mxDcT181VhPhqIYVlYMhuBeyuuvlKuwJLNj9_N8g",[272,290,303],{"id":273,"title":274,"date":275,"description":276,"extension":162,"image":277,"meta":278,"stem":286,"tags":287,"url":288,"__hash__":289},"projects/projects/1-men.yml","Для настоящих мужчин","2025-06-14T00:00:00.000Z","Для мужчин мы предлагаем стандартный, ускоренный и продвинутый курсы. Теоретическую часть советую прослушать всем, сколько бы лет Вы не отъездили за рулем мотоцикла. Уверен, узнаете про управление мотоциклом то, чего не представляли и о чем не задумывались.Без практики теория суха, а без теории практики не существует.Поверьте!","/images/gallery/49-e7838-f-be-97-4-a03-95-af-d28453-da-30-f2-1-201-a.jpeg",{"path":279,"links":280,"body":282},"/projects/1-men",[281],{"label":263,"color":32,"to":31},{"title":274,"description":276,"links":283,"tags":285,"image":277,"date":275},[284],{"label":263,"color":32,"to":31},[],"projects/1-men",[],null,"2Cl_Bk26xec_HOJ0Y6ZzprLFTo4Ffu-eULKnBj74Jo4",{"id":291,"title":292,"date":293,"description":294,"extension":162,"image":295,"meta":296,"stem":300,"tags":301,"url":288,"__hash__":302},"projects/projects/2-women.yml","Для милых дам","2025-06-15T00:00:00.000Z","В последнее время мототранспорт стал привлекать не только мужской, но и женский пол. С каждым годом девушек, желающих научиться ездить на мотоцикле, становится все больше. Добро пожаловать в школу! Школу мото!","/images/gallery/photo-2025-06-23-16.58.38.jpeg",{"path":297,"body":298},"/projects/2-women",{"tags":299,"title":292,"description":294,"image":295,"date":293},[],"projects/2-women",[],"sCrqhqWCiDaEE7YxCeZCwkw6K-D_7ODi8UEyXSLW-X4",{"id":304,"title":305,"date":306,"description":307,"extension":162,"image":308,"meta":309,"stem":313,"tags":314,"url":288,"__hash__":315},"projects/projects/3-childrens.yml","Для наших детей","2025-06-01T00:00:00.000Z","Для самых юных наших учеников, мы предлагаем курс получения базовых навыков управления мотоциклом. На ОГОРОЖЕННОЙ И БЕЗОПАСНОЙ территории Ваш ребёнок получит знания по физическим основам управления мотоциклом (узнает, почему, когда едет на велосипеде, может держать равновесие и не падает, а когда остановится — нет, приходится выставлять ногу), и научится ПРАВИЛЬНО использовать узлы и органы управления (для чего мотоциклисты »подгазовывают» в пробках?)","/images/gallery/photo-2025-06-23-17.00.21.jpeg",{"path":310,"body":311},"/projects/3-childrens",{"tags":312,"title":305,"description":307,"image":308,"date":306},[],"projects/3-childrens",[],"PPVJUg7gF9_4wOJknLvmoosm